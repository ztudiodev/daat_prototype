<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | DAAT</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.0/feather.min.js" integrity="sha512-Kolh2UJkNnRbl+uKf1nwZbmhICd5jPuuhSXsXmqGfZzPRv7fi8V+fhnjWqMEOd4rbyXZ1WOGcPC1nCzWYmGiVQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 font-inter">
    <div id="toast-container" class="fixed right-5 top-5 z-50 space-y-3"></div>
    <div class="flex min-h-screen">
      <%- include('partials/sidebar', { user }) %>
      <div class="flex-1">
        <%- include('partials/header', { user }) %>
        <main class="p-6 md:p-8">
          <%- body %>
        </main>
      </div>
    </div>
    <script>feather.replace();</script>
    <script src="/js/app.js"></script>
    <%- scripts || '' %>
  </body>
</html>
