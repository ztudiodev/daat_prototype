<header
	class="border-b border-slate-800 bg-slate-950/90 px-6 py-4 backdrop-blur-xl lg:px-8"
>
	<div
		class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between"
	>
		<div>
			<p class="text-xs text-cyan-300">SOC Dashboard</p>
			<h1 class="text-2xl font-semibold text-white"><%= title %></h1>
		</div>
		<div class="flex items-center gap-4">
			<div
				class="rounded-2xl bg-slate-900/90 px-4 py-3 text-sm text-slate-300 shadow-glow"
			>
				<span class="font-medium text-white">Estado:</span>
				<span class="ml-2 text-emerald-400">Estable</span>
			</div>
			<div
				class="hidden rounded-2xl bg-slate-900/90 px-4 py-3 text-sm text-slate-300 shadow-glow md:block"
			>
				<span class="font-medium text-white">Modo:</span>
				<span class="ml-2 text-cyan-300">Cybersecurity</span>
			</div>
		</div>
	</div>
</header>
