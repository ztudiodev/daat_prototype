<aside
	class="w-72 border-r border-slate-800 bg-slate-900/95 p-6 hidden lg:block"
>
	<div class="mb-10">
		<div class="mb-4 flex items-center gap-3">
			<span
				class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-500 text-slate-950"
				>DA</span
			>
			<div>
				<p class="text-sm text-slate-400">Plataforma DAAT</p>
				<p class="text-lg font-semibold text-white">SOC Analyst</p>
			</div>
		</div>
		<div
			class="rounded-3xl border border-slate-800 bg-slate-950/80 p-4 shadow-glow"
		>
			<p class="text-xs uppercase tracking-[0.28em] text-slate-500">Usuario</p>
			<p class="mt-2 font-semibold text-white">
				<%= user?.email || 'Invitado' %>
			</p>
			<p class="text-sm text-slate-400">
				Rol: <span class="font-medium"><%= user?.role || 'user' %></span>
			</p>
		</div>
	</div>
	<nav class="space-y-2 text-sm">
		<a
			href="/dashboard"
			class="flex items-center gap-3 rounded-3xl px-4 py-3 text-white transition hover:bg-slate-800 <%= title === 'Dashboard DAAT' ? 'bg-slate-800' : '' %>"
		>
			<i data-feather="home" class="h-4 w-4"></i>
			<span>Dashboard</span>
		</a>
		<a
			href="/analysis"
			class="flex items-center gap-3 rounded-3xl px-4 py-3 text-white transition hover:bg-slate-800 <%= title === 'Análisis de Correos' ? 'bg-slate-800' : '' %>"
		>
			<i data-feather="shield" class="h-4 w-4"></i>
			<span>Análisis de Correos</span>
		</a>
		<a
			href="/analysis/history"
			class="flex items-center gap-3 rounded-3xl px-4 py-3 text-white transition hover:bg-slate-800 <%= title === 'Historial de Análisis' ? 'bg-slate-800' : '' %>"
		>
			<i data-feather="clock" class="h-4 w-4"></i>
			<span>Historial</span>
		</a>
		<form action="/logout" method="post" class="mt-6">
			<button
				type="submit"
				class="flex w-full items-center justify-center gap-2 rounded-3xl bg-rose-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-rose-400"
			>
				<i data-feather="log-out" class="h-4 w-4"></i>
				Logout
			</button>
		</form>
	</nav>
</aside>
