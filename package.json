		"express-validator": "^7.0.1",
		"helmet": "^7.0.0",
		"jsonwebtoken": "^9.0.2",
		"morgan": "^1.10.0",
		"pg": "^8.12.0",
		"pg-hstore": "^2.3.4",
		"sequelize": "^6.33.0",
		"tailwindcss": "^3.4.4"
